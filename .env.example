# Which LLM provider to use: mock | openai | gemini | groq
# "mock" requires no API key and runs fully offline — good for testing routing/RAG first.
LLM_PROVIDER=mock

# Set the key matching your chosen provider
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# SQLite is used by default for conversation memory — no setup required.
# Override the path if you want, or swap database/memory.py for Mongo/Postgres.
SQLITE_PATH=./backend/database/conversations.db
